{
  "expo": {
    "name": "RouteFlow",
    "slug": "routeflow",
    "scheme": "routeflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.routeflow.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "RouteFlow uses your camera to add photos to trip memories",
        "NSPhotoLibraryUsageDescription": "RouteFlow accesses your photos for trip covers and memories",
        "NSPhotoLibraryAddUsageDescription": "RouteFlow saves shared trip images to your library when you choose to",
        "NSLocationWhenInUseUsageDescription": "RouteFlow uses your location to find nearby places",
        "NSUserNotificationsUsageDescription": "RouteFlow sends reminders about your trips and expense updates"
      }
    },
    "android": {
      "package": "com.routeflow.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-updates",
      [
        "expo-image-picker",
        {
          "photosPermission": "RouteFlow accesses your photos for trip covers and memories",
          "cameraPermission": "RouteFlow uses your camera to add photos to trip memories"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "routeflow",
          "project": "routeflow"
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://routeflow.app/privacy"
    }
  }
}
